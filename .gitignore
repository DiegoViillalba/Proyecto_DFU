# ==========================================
# GitIgnore - Proyecto DFU
# ==========================================

# --- Entornos Virtuales y Dependencias ---
.venv/
venv/
env/
ENV/
bin/
lib/
develop-eggs/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Cachés de Python ---
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.tox/
.nox/
.coverage
.cache
htmlcov/
.mypy_cache/
.pyre/
.pytype/
pip-log.txt
pip-delete-this-directory.txt

# --- Jupyter Notebooks ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# --- IDEs y Editores de Código ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.codegpt/
.gemini/

# --- Control de Versiones de Datos (DVC) y Caché ---
# Nota: DVC maneja el dataset dentro de data/, pero aseguramos su exclusión en git.
data/dfu_tissue/
data/miccai/

# --- Checkpoints y Pesos Pesados de Entrenamiento ---
# Excluye todas las carpetas output_assets_model donde los scripts guardan métricas y checkpoints
**/output_assets_model/
**/saved_images/

# Extensiones de archivos pesados y checkpoints de Deep Learning
*.pth
*.pth.tar
*.zip
*.mat
*.h5
*.hdf5
*.ckpt
*.weights

# Exceptuar pesos finales oficiales en la carpeta weights/
!weights/
!weights/*.tflite

# --- Resultados temporales e imágenes generadas de Gerardo (Legacy) ---
**/Images_Gerardo/new_masks_68/
**/Images_Gerardo/new_maks_4classes_68/
**/Images_Gerardo/pred_masks_68*/
**/Images_Gerardo/pred_masks_4classes_68*/
